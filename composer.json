{
    "name": "phpkg/laravel-foundation",
    "license": "Apache-2.0",
    "require": {
        "php": "^8.3",
        "alibabacloud/aliyun-log-php-sdk": "^0.6",
        "laravel/framework": "^13.11"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Juling\\Foundation\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Juling\\Foundation\\FoundationServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
